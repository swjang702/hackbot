obj-m := hackbot.o

# Generate a Rust file with the kernel version string so that hackbot.rs
# can embed it at compile time without depending on unexported linux_banner.
# KERNELRELEASE is set by the kernel build system (e.g., "6.19.8").
$(obj)/hackbot.o: $(obj)/kernel_version.rs

$(obj)/kernel_version.rs: FORCE
	@echo '/// Auto-generated by Kbuild — do not edit.' > $@
	@echo 'pub(crate) const KERNEL_RELEASE: &[u8] = b"$(KERNELRELEASE)";' >> $@

clean-files += kernel_version.rs

FORCE:
